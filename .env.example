# Copy this file to .env (which is gitignored) and fill in your key.
# Loaded automatically by tts/demo.py and tts/demo_bridge.py via python-dotenv.

GROQ_API_KEY=your_groq_api_key_here

# Optional: override Groq model IDs if the defaults get deprecated.
# GROQ_LLM_MODEL=llama-3.3-70b-versatile
# GROQ_STT_MODEL=whisper-large-v3-turbo

# Optional (local demo): pin audio devices if the system default is a virtual cable.
# MIC_DEVICE_INDEX=
# SPEAKER_DEVICE_INDEX=

# Optional (bridge demo): URL of the megakernel TTS server (default shown).
# TTS_URL=http://localhost:8090/tts
